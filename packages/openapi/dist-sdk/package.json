{
  "name": "@metasheet/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for MetaSheet V2 API",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./client": {
      "types": "./client.d.ts",
      "import": "./client.js"
    }
  },
  "files": ["index.js", "index.d.ts", "client.js", "client.d.ts"],
  "scripts": {
    "build": "node ./scripts/build.mjs && tsc -p tsconfig.json",
    "lint": "eslint \"client.ts\"",
    "test": "vitest run --config vitest.config.mts",
    "type-check": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": ["metasheet","sdk","openapi"],
  "license": "UNLICENSED"
}
