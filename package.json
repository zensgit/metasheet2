{
  "name": "metasheet-v2",
  "version": "2.5.0",
  "description": "Next-generation collaborative spreadsheet platform with microkernel architecture",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @metasheet/web dev",
    "poc:univer:start": "bash scripts/start-univer-poc.sh",
    "poc:univer:start:mock": "BACKEND_MODE=mock bash scripts/start-univer-poc.sh",
    "poc:univer:start:core": "BACKEND_MODE=core bash scripts/start-univer-poc.sh",
    "poc:univer:stop": "bash scripts/stop-univer-poc.sh",
    "poc:univer:verify": "bash scripts/verify-univer-all.sh",
    "poc:univer:verify:core": "BACKEND_MODE=core bash scripts/verify-univer-all.sh",
    "verify:readonly-ui": "NODE_PATH=apps/web-react/node_modules node scripts/verify-readonly-ui.cjs",
    "verify:readonly-suite": "bash scripts/verify-readonly-suite.sh",
    "verify:readonly-start": "bash scripts/start-univer-verify-readonly.sh",
    "verify:comments": "NODE_PATH=apps/web-react/node_modules node scripts/verify-comments-summary.mjs && NODE_PATH=apps/web-react/node_modules node scripts/verify-comments-ui.cjs",
    "verify:editable-demo": "NODE_PATH=apps/web-react/node_modules node scripts/verify-editable-demo-ui.cjs",
    "verify:smoke": "node scripts/verify-smoke-core.mjs && pnpm verify:attendance-ui:optional",
    "verify:labs-gating": "NODE_PATH=apps/web-react/node_modules node scripts/verify-labs-gating-ui.cjs",
    "verify:smoke:all": "bash scripts/verify-smoke.sh",
    "verify:plm-ui-regression": "bash scripts/verify-plm-ui-regression.sh",
    "verify:plm-ui-full": "bash scripts/verify-plm-ui-full.sh",
    "verify:plm-regression": "bash scripts/verify-plm-regression.sh",
    "verify:attendance-ui": "node scripts/verify-attendance-ui.mjs",
    "verify:attendance-import-ui": "node scripts/verify-attendance-import-ui.mjs",
    "verify:attendance-ui-regression": "node scripts/verify-attendance-ui-regression.mjs",
    "verify:attendance-locale-zh": "node scripts/verify-attendance-locale-zh-smoke.mjs",
    "verify:attendance-zh-copy-contract": "node scripts/ops/attendance-verify-zh-copy-contract.mjs",
    "verify:attendance-regression-local": "bash scripts/ops/attendance-regression-local.sh",
    "verify:attendance-regression-fast": "bash scripts/ops/attendance-fast-parallel-regression.sh",
    "verify:attendance-regression-fast:test": "node --test scripts/ops/attendance-fast-parallel-regression.test.mjs",
    "verify:attendance-regression-fast:ops": "PROFILE=ops MAX_PARALLEL=2 bash scripts/ops/attendance-fast-parallel-regression.sh",
    "verify:attendance-regression-fast:contracts": "PROFILE=contracts MAX_PARALLEL=1 bash scripts/ops/attendance-fast-parallel-regression.sh",
    "verify:attendance-regression-fast:report": "node scripts/ops/attendance-fast-parallel-summary-report.mjs",
    "verify:attendance-regression-fast:report:test": "node --test scripts/ops/attendance-fast-parallel-summary-report.test.mjs",
    "verify:attendance-post-merge": "bash scripts/ops/attendance-post-merge-verify.sh",
    "verify:attendance-ui:optional": "bash -c 'if [ \"${RUN_ATTENDANCE_UI_SMOKE}\" = \"true\" ]; then node scripts/verify-attendance-ui.mjs; else echo \"skip attendance ui (set RUN_ATTENDANCE_UI_SMOKE=true)\"; fi'",
    "verify:univer-ui-smoke": "node scripts/verify-univer-ui-smoke.mjs",
    "verify:multitable-pilot": "node scripts/verify-multitable-live-smoke.mjs",
    "verify:multitable-pilot:local": "bash scripts/ops/multitable-pilot-local.sh",
    "verify:multitable-pilot:local:test": "node --test scripts/ops/multitable-pilot-local.test.mjs",
    "verify:multitable-pilot:staging": "bash scripts/ops/multitable-pilot-staging.sh",
    "verify:multitable-pilot:staging:test": "node --test scripts/ops/multitable-pilot-staging.test.mjs",
    "verify:multitable-pilot:readiness": "node scripts/ops/multitable-pilot-readiness.mjs",
    "verify:multitable-pilot:readiness:test": "node --test scripts/ops/multitable-pilot-readiness.test.mjs",
    "verify:multitable-pilot:ready:local": "bash scripts/ops/multitable-pilot-ready-local.sh",
    "verify:multitable-pilot:ready:local:test": "node --test scripts/ops/multitable-pilot-ready-local.test.mjs",
    "verify:multitable-pilot:ready:staging": "bash scripts/ops/multitable-pilot-ready-staging.sh",
    "verify:multitable-pilot:ready:staging:test": "node --test scripts/ops/multitable-pilot-ready-staging.test.mjs",
    "verify:multitable-pilot:ready:local:release-bound": "bash scripts/ops/multitable-pilot-ready-release-bound.sh",
    "verify:multitable-pilot:ready:staging:release-bound": "RUN_MODE=staging bash scripts/ops/multitable-pilot-ready-release-bound.sh",
    "verify:multitable-pilot:release-gate": "bash scripts/ops/multitable-pilot-release-gate.sh",
    "verify:multitable-pilot:release-gate:staging": "RUN_MODE=staging bash scripts/ops/multitable-pilot-release-gate.sh",
    "verify:multitable-pilot:release-gate:test": "node --test scripts/ops/multitable-pilot-release-gate.test.mjs",
    "verify:multitable-openapi:parity": "pnpm exec tsx packages/openapi/tools/build.ts && node --test scripts/ops/multitable-openapi-parity.test.mjs",
    "prepare:multitable-pilot:handoff": "node scripts/ops/multitable-pilot-handoff.mjs",
    "prepare:multitable-pilot:handoff:release-bound": "bash scripts/ops/multitable-pilot-handoff-release-bound.sh",
    "prepare:multitable-pilot:handoff:staging:release-bound": "RUN_MODE=staging bash scripts/ops/multitable-pilot-handoff-release-bound.sh",
    "prepare:multitable-pilot:release-bound": "bash scripts/ops/multitable-pilot-release-bound.sh",
    "prepare:multitable-pilot:release-bound:staging": "RUN_MODE=staging bash scripts/ops/multitable-pilot-release-bound.sh",
    "build:multitable-onprem-package": "bash scripts/ops/multitable-onprem-package-build.sh",
    "verify:multitable-onprem:release-gate": "bash scripts/ops/multitable-onprem-release-gate.sh",
    "prepare:multitable-onprem:delivery": "node scripts/ops/multitable-onprem-delivery-bundle.mjs",
    "profile:multitable-grid": "node scripts/profile-multitable-grid.mjs",
    "profile:multitable-grid:local": "RUNNER_SCRIPT=scripts/profile-multitable-grid.mjs RUN_LABEL=multitable-grid-profile bash scripts/ops/multitable-pilot-local.sh",
    "profile:multitable-grid:staging": "RUNNER_SCRIPT=scripts/profile-multitable-grid.mjs RUN_LABEL=multitable-grid-profile-staging RUN_MODE=staging RUNNER_REPORT_BASENAME=staging-report AUTO_START_SERVICES=false REQUIRE_RUNNING_SERVICES=true bash scripts/ops/multitable-pilot-local.sh",
    "verify:multitable-grid-profile:summary": "node scripts/ops/multitable-grid-profile-summary.mjs",
    "phase5:run-all": "bash scripts/phase5-run-all.sh",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "validate:plugins": "npx tsx scripts/validate-plugin-manifests.ts",
    "devtools:attach": "tsx scripts/attach-chrome-devtools.ts",
    "validate:all": "pnpm validate:plugins && pnpm lint && pnpm type-check",
    "staging:validate": "bash scripts/verify-sprint2-staging.sh $API_TOKEN $BASE_URL",
    "staging:perf": "bash scripts/performance-baseline-test.sh $API_TOKEN $BASE_URL",
    "staging:schema": "bash scripts/dump-sprint2-schema.sh",
    "staging:pr-body": "bash scripts/generate-sprint2-pr-body.sh",
    "staging:promql": "bash scripts/promql-smoke-check.sh",
    "test:plm": "pnpm dlx tsx packages/core-backend/scripts/test-plm-connection.ts",
    "metrics:test": "bash scripts/test-metrics-integration.sh",
    "metrics:cli": "bash scripts/metrics-cli.sh",
    "metrics:dashboard": "bash scripts/metrics-cli.sh dashboard",
    "metrics:watch": "bash scripts/metrics-cli.sh watch",
    "metrics:health": "bash scripts/metrics-cli.sh health",
    "metrics:alert": "node examples/metrics-alerting.js",
    "test:adapters": "bash scripts/test-plm-complete.sh && bash scripts/test-athena-complete.sh",
    "verify:yuantus": "bash scripts/verify-yuantus-plm.sh",
    "test:formdata": "bash scripts/test-formdata-upload.sh",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:dev:logs": "docker-compose -f docker-compose.dev.yml logs -f",
    "docker:build": "docker build -t metasheet-backend -f Dockerfile.backend . && docker build -t metasheet-frontend -f Dockerfile.frontend .",
    "monitoring:setup": "bash scripts/setup-monitoring.sh",
    "db:backup": "bash scripts/backup-restore.sh backup",
    "db:restore": "bash scripts/backup-restore.sh restore",
    "db:list-backups": "bash scripts/backup-restore.sh list",
    "db:clean-backups": "bash scripts/backup-restore.sh clean",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:start:prod": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "^5.4.0"
    }
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@univerjs/themes": "^0.15.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.19.2",
    "js-yaml": "^4.1.1",
    "preact": "^10.28.1",
    "prettier": "^3.1.1",
    "tsx": "^4.20.6",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "keywords": [
    "spreadsheet",
    "collaboration",
    "microkernel",
    "bpmn",
    "observability",
    "metasheet"
  ],
  "author": "MetaSheet Team",
  "license": "Private",
  "repository": {
    "type": "git",
    "url": "https://github.com/zensgit/metasheet2.git"
  }
}
